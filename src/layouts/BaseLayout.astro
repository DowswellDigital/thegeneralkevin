---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const defaultDescription = "Kevin 'The General' Neal — 2× CCMA-nominated pedal steel and dobro player. Session musician and touring artist based in Hamilton, Ontario. Available worldwide for live performance, studio sessions, and touring.";
const { title, description = defaultDescription, ogImage = '/kevin1.png' } = Astro.props;
const canonicalURL = `https://thegeneralkevin.com${Astro.url.pathname}`;
const ogImageURL = `https://thegeneralkevin.com${ogImage}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MusicGroup',
  'name': 'Kevin "The General" Neal',
  'url': 'https://thegeneralkevin.com',
  'image': ogImageURL,
  'description': defaultDescription,
  'genre': ['Country', 'Roots', 'Folk'],
  'member': {
    '@type': 'Person',
    'name': 'Kevin Neal',
    'alternateName': 'The General',
    'knowsAbout': ['Pedal Steel Guitar', 'Dobro'],
    'jobTitle': 'Session Musician & Touring Artist',
  },
  'location': {
    '@type': 'Place',
    'name': 'Hamilton, Ontario, Canada',
  },
  'sameAs': [
    'https://instagram.com/thegeneralkev',
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalURL}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImageURL}>
  <meta property="og:site_name" content="Kevin 'The General' Neal">
  <meta property="og:locale" content="en_CA">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageURL}>

  <!-- Additional SEO -->
  <meta name="author" content="Kevin Neal">
  <meta name="keywords" content="pedal steel, dobro, session musician, touring musician, Kevin Neal, The General, CCMA, country music, Hamilton Ontario, pedal steel player, Jade Eagleson, studio sessions">
  <meta name="robots" content="index, follow">
  <meta name="geo.region" content="CA-ON">
  <meta name="geo.placename" content="Hamilton, Ontario">

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-B4RF36ZKGN"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-B4RF36ZKGN');
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
  <footer>
    <div class="footer-name">Kevin "The General" Neal</div>
    <div class="footer-handle">thegeneralkevin.com</div>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  footer {
    background: var(--dark);
    padding: 32px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(201, 168, 76, 0.08);
  }

  .footer-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    letter-spacing: 4px;
    color: var(--light-mid);
  }

  .footer-handle {
    font-family: 'Courier Prime', monospace;
    font-size: 12px;
    color: var(--light-mid);
  }

  @media (max-width: 900px) {
    footer {
      padding: 24px 32px;
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>

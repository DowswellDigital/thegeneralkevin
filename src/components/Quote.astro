---
interface Props {
  text: string;
  attribution: string;
}

const { text, attribution } = Astro.props;
---

<section class="quote-section">
  <blockquote class="pull-quote">
    {text}
  </blockquote>
  <p class="quote-attr">&mdash; {attribution}</p>
</section>

<style>
  .quote-section {
    padding: 100px 60px;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .pull-quote {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-style: italic;
    line-height: 1.3;
    color: var(--cream);
    position: relative;
    padding: 0 60px;
  }

  .pull-quote::before,
  .pull-quote::after {
    content: '\201C';
    font-size: 120px;
    color: rgba(201, 168, 76, 0.15);
    font-family: 'Playfair Display', serif;
    position: absolute;
    line-height: 1;
  }

  .pull-quote::before { top: -20px; left: 0; }
  .pull-quote::after { bottom: -60px; right: 0; content: '\201D'; }

  .quote-attr {
    font-family: 'Courier Prime', monospace;
    font-size: 12px;
    letter-spacing: 3px;
    color: var(--rust);
    text-transform: uppercase;
    margin-top: 48px;
  }

  @media (max-width: 900px) {
    .quote-section { padding: 60px 32px; }
  }
</style>

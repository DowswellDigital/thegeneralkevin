---
---

<section class="hero">
  <div class="hero-left">
    <div class="rank-badge">2× CCMA Nominated · Pedal Steel & Dobro</div>
    <h1 class="hero-name">
      Kevin Neal
      <span>The General</span>
    </h1>
    <p class="hero-instrument">Hamilton, Ontario · Available Worldwide</p>
  </div>

  <div class="hero-right">
    <img src="/kevin1.png" alt="Kevin 'The General' Neal with his pedal steel guitar" class="hero-image" />
    <div class="stats-grid">
      <div class="stat-cell">
        <div class="stat-number">2&times;</div>
        <div class="stat-label">CCMA Nominated<br>Pedal Steel Player</div>
      </div>
      <div class="stat-cell">
        <div class="stat-number">3</div>
        <div class="stat-label">Continents.<br>Countless Stages.</div>
      </div>
      <div class="stat-cell">
        <div class="stat-number">Grand<br><span style="font-size:24px">Ole Opry</span></div>
        <div class="stat-label">Performance Credit</div>
      </div>
      <div class="stat-cell">
        <div class="stat-number">Sessions</div>
        <div class="stat-label">Recorded With Artists<br>Around the World</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    background: var(--dark);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 60px;
    position: relative;
    z-index: 2;
  }

  .hero-left::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--gold), transparent);
  }

  .rank-badge {
    display: inline-block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 6px 14px;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.2s;
  }

  .hero-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(52px, 7vw, 96px);
    font-weight: 900;
    font-style: italic;
    line-height: 0.9;
    color: var(--cream);
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.4s;
  }

  .hero-name span {
    display: block;
    color: var(--gold);
    font-size: clamp(32px, 4vw, 56px);
    font-weight: 400;
    font-style: normal;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 6px;
    margin-top: 8px;
  }

  .hero-instrument {
    font-family: 'Courier Prime', monospace;
    font-size: 13px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--light-mid);
    margin-top: 32px;
    opacity: 0;
    animation: fadeUp 0.8s ease forwards 0.6s;
  }

  .hero-instrument::before {
    content: '— ';
    color: var(--rust);
  }

  .hero-right {
    position: relative;
    background: linear-gradient(135deg, #2A1F18 0%, #0D0A08 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.3;
    z-index: 1;
  }

  .hero-right::before {
    content: 'THE\AGENERAL';
    white-space: pre;
    position: absolute;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 200px;
    line-height: 0.85;
    color: rgba(201, 168, 76, 0.04);
    letter-spacing: -4px;
    text-align: center;
    animation: slowDrift 20s ease-in-out infinite alternate;
  }

  .stats-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    width: 100%;
    height: 100%;
  }

  .stat-cell {
    background: rgba(26, 22, 18, 0.6);
    backdrop-filter: blur(4px);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid rgba(201, 168, 76, 0.08);
    opacity: 0;
    animation: fadeIn 1s ease forwards;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .stat-cell:hover {
    background: rgba(201, 168, 76, 0.06);
    border-color: rgba(201, 168, 76, 0.2);
  }

  .stat-cell:nth-child(1) { animation-delay: 0.5s; }
  .stat-cell:nth-child(2) { animation-delay: 0.7s; }
  .stat-cell:nth-child(3) { animation-delay: 0.9s; }
  .stat-cell:nth-child(4) { animation-delay: 1.1s; }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
  }

  .stat-label {
    font-family: 'Courier Prime', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--light-mid);
    margin-top: 8px;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 60px 32px; }
    .hero-right { min-height: 60vw; }
  }
</style>

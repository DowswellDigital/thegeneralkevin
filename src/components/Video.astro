---
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'Video' } = Astro.props;
---

<section class="video-section">
  <div class="section-label">// Watch</div>
  <div class="video-wrapper">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${videoId}`}
      title={title}
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</section>

<style>
  .video-section {
    padding: 80px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    margin-top: 48px;
    border: 1px solid rgba(201, 168, 76, 0.15);
    background: #0D0A08;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .video-section { padding: 60px 32px; }
  }
</style>
